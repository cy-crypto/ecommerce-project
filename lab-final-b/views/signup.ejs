<%- include('partials/header') %>

<section class="auth-wrap">
  <h1>Create Account</h1>
  <% if (error) { %><p class="error-text"><%= error %></p><% } %>
  <form method="POST" action="/auth/signup" class="auth-form">
    <label>Full Name <input type="text" name="name" required /></label>
    <label>Email <input type="email" name="email" required /></label>
    <label>Phone <input type="text" name="phone" /></label>
    <label>Address <textarea name="address" rows="3"></textarea></label>
    <label>Password <input type="password" name="password" minlength="6" required /></label>
    <label>Confirm Password <input type="password" name="confirmPassword" minlength="6" required /></label>
    <button type="submit" class="btn-primary">Sign Up</button>
  </form>
  <p>Already have an account? <a href="/auth/signin">Sign in</a></p>
</section>

<%- include('partials/footer') %>