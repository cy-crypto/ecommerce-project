<%- include('partials/header') %>

<section class="checkout-page">
  <div class="container">
    <h1 class="page-title">Checkout</h1>
    <p class="page-subtitle">Confirm your shipping details and order plan.</p>

    <div class="checkout-grid">
      <div class="checkout-form-card">
        <h2>Shipping Details</h2>
        <form method="POST" action="/order/preview" class="checkout-form">
          <label>Name <input type="text" name="name" value="<%= profile.name %>" required /></label>
          <label>Email <input type="email" name="email" value="<%= profile.email %>" required /></label>
          <label>Phone <input type="text" name="phone" value="<%= profile.phone || '' %>" required /></label>
          <label>Address <textarea name="address" required><%= profile.address || '' %></textarea></label>
          <label>Order Plan
            <select name="plan" required>
              <option value="one-time">One-Time Order</option>
              <option value="subscription">Weekly Subscription</option>
            </select>
          </label>
          <label>Coupon Code <input type="text" name="couponCode" placeholder="Optional" /></label>
          <button type="submit" class="btn-primary">Preview Order</button>
        </form>
      </div>

      <aside class="checkout-summary-card">
        <h2>Order Summary</h2>
        <% cartItems.forEach(item => { %>
          <div class="summary-row">
            <p><strong><%= item.product.name %></strong> x <%= item.quantity %></p>
            <p>$<%= item.itemTotal.toFixed(2) %></p>
          </div>
          <% if (item.selectedFlavours && item.selectedFlavours.length) { %>
            <p class="muted summary-flavours">Flavours: <%= item.selectedFlavours.join(', ') %></p>
          <% } %>
        <% }) %>
        <hr />
        <p class="summary-row"><span>Subtotal</span><strong>$<%= subtotal.toFixed(2) %></strong></p>
        <p class="summary-row"><span>Tax</span><strong>$<%= tax.toFixed(2) %></strong></p>
        <p class="summary-row"><span>Shipping</span><strong>$<%= shipping.toFixed(2) %></strong></p>
        <p class="summary-row total"><span>Total</span><strong>$<%= total.toFixed(2) %></strong></p>
      </aside>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
