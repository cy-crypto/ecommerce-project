<%- include('partials/header') %>

<section>
  <h1>Categories</h1>

  <h2>Add Category</h2>
  <form method="POST" action="/admin/categories" class="admin-form">
    <label>Name <input type="text" name="name" required /></label>
    <label>Description <textarea name="description"></textarea></label>
    <button type="submit" class="admin-btn">Add Category</button>
  </form>

  <h2>Existing Categories</h2>
  <table class="data-table">
    <thead><tr><th>Name</th><th>Description</th><th>Actions</th></tr></thead>
    <tbody>
      <% categories.forEach(category => { %>
        <tr>
          <td>
            <form method="POST" action="/admin/categories/<%= category._id %>" class="inline-form">
              <input type="text" name="name" value="<%= category.name %>" required />
          </td>
          <td><textarea name="description"><%= category.description || '' %></textarea></td>
          <td>
              <button type="submit">Update</button>
            </form>
            <form method="POST" action="/admin/categories/<%= category._id %>/delete" class="inline-form">
              <button type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('partials/footer') %>