<%- include('partials/header') %>

<section class="home-video-hero">
  <video class="home-video-hero__media" autoplay muted loop playsinline preload="metadata" poster="/assets/main-section-imge.jpg" aria-label="ScoopCraft featured video">
    <source src="/assets/main-section-video.mp4" type="video/mp4" />
    Your browser does not support the video tag.
  </video>
  <div class="home-video-hero__overlay" aria-hidden="true"></div>
  <div class="home-video-hero__content">
    <span class="home-video-hero__kicker">Freshly Churned Daily</span>
    <h1>Design your custom pint in minutes.</h1>
    <p>Pick your layers, place the order, and get artisan ice cream delivered cold and fast.</p>
  </div>
  <a href="/products" class="btn-primary home-video-hero__cta">Explore Products</a>
</section>

<section class="hero-icecream">
  <div class="container hero-grid">
    <div class="hero-content-col sc-animate" data-animate="fade-right">
      <span class="kicker">Custom Ice Cream Pints</span>
      <h1>Craft your dream pint with chef-curated layers and doorstep delivery.</h1>
      <p>
        ScoopCraft is a premium dessert commerce experience where each pint is made to order.
        Build 3-layer classics or 4-layer deluxe pints, then choose one-time delivery or subscription.
      </p>
      <div class="hero-actions">
        <a href="/products" class="btn-primary btn-glow">Build My Pint</a>
        <a href="/checkout" class="btn-outline">Start Secure Checkout</a>
      </div>

    </div>
    <div class="hero-visual sc-animate" data-animate="fade-left">
      <img src="/assets/main-section-imge.jpg" alt="ScoopCraft hero pint showcase" class="hero-banner-image" />
      <div class="pint-card">
        <h3>Signature Stack of The Week</h3>
        <p><%= signatureStack || 'Add flavour options in dashboard to build your live signature stack.' %></p>
      </div>
    </div>
  </div>
</section>

<section class="flavour-marquee" aria-label="Featured flavour visuals">
  <div class="flavour-marquee__viewport">
    <div class="flavour-marquee__track">
      <article class="flavour-marquee__item">
        <img src="/assets/swet.png" alt="Atom flavour visual" loading="lazy" />
        <span>Atom</span>
      </article>
            <article class="flavour-marquee__item">
        <img src="/assets/fresh.png" alt="Atom flavour visual" loading="lazy" />
        <span>Atom</span>
      </article>
      <article class="flavour-marquee__item">
        <img src="/assets/swirl.png" alt="Swirl flavour visual" loading="lazy" />
        <span>Swirl</span>
      </article>
      <article class="flavour-marquee__item">
        <img src="/assets/yum.png" alt="Yum flavour visual" loading="lazy" />
        <span>Yum</span>
      </article>
      <article class="flavour-marquee__item">
        <img src="/assets/icy.png" alt="Atom flavour visual" loading="lazy" />
        <span>Atom</span>
      </article>

      <article class="flavour-marquee__item" aria-hidden="true">
        <img src="/assets/swirl.png" alt="" loading="lazy" />
        <span>Swirl</span>
      </article>
      <article class="flavour-marquee__item" aria-hidden="true">
        <img src="/assets/yum.png" alt="" loading="lazy" />
        <span>Yum</span>
      </article>
    </div>
  </div>
</section>

<section class="nitrogen-process">
  <div class="container nitrogen-process__grid">
    <div class="nitrogen-process__content">
      <h2>Our Nitrogen Process</h2>
      <p>
        We use liquid nitrogen to flash-freeze every order, resulting in a velvety texture and unparalleled creaminess.
        This rapid freezing process locks in both freshness and flavor, delivering a pint of ice cream that offers a dessert experience like no other.
      </p>
      <a href="/products" class="btn-primary">Order Now</a>
    </div>
    <div class="nitrogen-process__media">
      <video autoplay muted loop playsinline preload="metadata" poster="/assets/main-section-imge.jpg" aria-label="Our nitrogen process video">
        <source src="/assets/our%20nitrogen%20process.mp4" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>
  </div>
</section>


<section class="flavour-showcase home-flavour-slider" aria-label="Signature flavour highlights">
  <div class="container">
    <h2 class="section-title sc-animate" data-animate="fade-up">Signature Flavours</h2>
    <p class="page-subtitle sc-animate" data-animate="fade-up">Browse our showcase picks.</p>

    <div class="home-flavour-slider__shell sc-animate" data-animate="fade-up" data-delay="80" id="homeFlavourSlider">
      <div class="home-flavour-slider__viewport">
        <div class="home-flavour-slider__track">
          <article class="home-flavour-slide is-active" data-slide="0">
            <a href="/products/69d4baeafb7457e176e1a6f8" class="home-flavour-slide__link" aria-label="Open product page">
              <img src="/assets/pista-homepage.jpg" alt="Pista home flavour" />
              <span>View Product</span>
            </a>
          </article>
          <article class="home-flavour-slide" data-slide="1">
            <a href="/products/69d4baeafb7457e176e1a6f5" class="home-flavour-slide__link" aria-label="Open product page">
              <img src="/assets/yellow-cream-homepage.webp" alt="Yellow cream home flavour" />
              <span>View Product</span>
            </a>
          </article>
          <article class="home-flavour-slide" data-slide="2">
            <a href="/products/69d4be3bbea7ebcf1328a6d4" class="home-flavour-slide__link" aria-label="Open product page">
              <img src="/assets/custard-homepage.webp" alt="Custard home flavour" />
              <span>View Product</span>
            </a>
          </article>
          <article class="home-flavour-slide" data-slide="3">
            <a href="/products/69d4be3bbea7ebcf1328a6d1" class="home-flavour-slide__link" aria-label="Open product page">
              <img src="/assets/chocolate-homepage.webp" alt="Chocolate home flavour" />
              <span>View Product</span>
            </a>
          </article>
          <article class="home-flavour-slide" data-slide="4">
            <a href="/products/69d4baeafb7457e176e1a6fb" class="home-flavour-slide__link" aria-label="Open product page">
              <img src="/assets/straw-homepage.jpg" alt="Strawberry home flavour" />
              <span>View Product</span>
            </a>
          </article>
        </div>
      </div>

      <button type="button" class="home-flavour-slider__arrow home-flavour-slider__arrow--prev" aria-label="Previous slide">&#10094;</button>
      <button type="button" class="home-flavour-slider__arrow home-flavour-slider__arrow--next" aria-label="Next slide">&#10095;</button>

      <div class="home-flavour-slider__dots" role="tablist" aria-label="Flavour slides"></div>
    </div>
  </div>
</section>

<section class="catalog-showcase">
  <div class="container">
    <h2 class="section-title sc-animate" data-animate="fade-up">Explore Pint Collection</h2>
    <!-- <p class="page-subtitle sc-animate" data-animate="fade-up">Pick from 4 live products and customize each scoop profile before checkout.</p> -->
    <div class="products-grid featured-products-grid">
      <% if (featuredProducts && featuredProducts.length) { %>
        <% featuredProducts.slice(0, 4).forEach((product, idx) => { %>
          <article class="product-card product-card-clickable sc-animate" data-animate="fade-up" data-delay="<%= idx * 80 %>" data-href="/products/<%= product._id %>" tabindex="0" role="link" aria-label="Open <%= product.name %>">
            <img src="<%= product.image %>" alt="<%= product.name %>" class="product-image" />
            <h3><%= product.name %></h3>
            <p class="product-card__desc"><%= product.shortDescription || product.description %></p>
            <p class="product-price"><strong>$<%= Number(product.price || 0).toFixed(2) %></strong></p>
            <a href="/products/<%= product._id %>" class="btn-primary">Customize</a>
          </article>
        <% }) %>
        <div class="shop-all-wrap sc-animate" data-animate="fade-up" data-delay="120">
          <a href="/products" class="btn-primary btn-glow">Shop All</a>
        </div>
      <% } else { %>
        <article class="builder-card">
          <h3>Catalog is warming up</h3>
          <p>Add products from the admin dashboard and they will show here automatically.</p>
          <a href="/admin/products" class="btn-primary">Open Dashboard</a>
        </article>
      <% } %>
    </div>
  </div>
</section>

<section class="faq-section">
  <div class="container">
    <h2 class="section-title sc-animate" data-animate="fade-up">Frequently Asked Questions</h2>
    <div class="faq-accordion">
      <details class="faq-item sc-animate" data-animate="fade-up" data-delay="0">
        <summary>How do I build a custom pint?</summary>
        <div class="faq-answer">
          <p>Open the products page, choose your pint, and select your flavour layers. You can create 3-layer classics or 4-layer deluxe combinations before adding to cart.</p>
        </div>
      </details>
      <details class="faq-item sc-animate" data-animate="fade-up" data-delay="100">
        <summary>How is delivery handled so the ice cream stays fresh?</summary>
        <div class="faq-answer">
          <p>Every order is packed using cold-chain safe packaging designed to maintain texture and temperature from our kitchen to your doorstep.</p>
        </div>
      </details>
      <details class="faq-item sc-animate" data-animate="fade-up" data-delay="200">
        <summary>Can I place one-time orders and subscriptions?</summary>
        <div class="faq-answer">
          <p>Yes. At checkout you can select either one-time delivery or a subscription plan, depending on how often you want fresh pints delivered.</p>
        </div>
      </details>
      <details class="faq-item sc-animate" data-animate="fade-up" data-delay="300">
        <summary>How do I track my order after purchase?</summary>
        <div class="faq-answer">
          <p>After placing an order, sign in and open My Orders or Track Order to view live status updates and delivery progress.</p>
        </div>
      </details>
    </div>
  </div>
</section>
<section class="social-proof">
  <div class="container">
    <h2 class="section-title sc-animate" data-animate="fade-up">Loved by Dessert Fans</h2>
    <div class="icon-grid">
      <article class="icon-card sc-animate" data-animate="fade-up" data-delay="0">
