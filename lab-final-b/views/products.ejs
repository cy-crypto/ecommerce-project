<%- include('partials/header') %>

<section class="builder-hero">
  <div class="container">
    <h1>Shop and Customize Your Pint</h1>
    <p>Browse our catalog, filter flavours, and configure each pint before adding to cart.</p>
  </div>
</section>

<section class="builder-section">
  <div class="container">
    <form method="GET" action="/products" class="filter-form">
      <label>Search
        <input type="text" name="q" value="<%= q || '' %>" placeholder="Search pints or flavours" />
      </label>
      <button type="submit" class="btn-primary">Apply Filters</button>
      <a href="/products" class="btn-outline">Reset</a>
    </form>

    <div class="products-grid spacious">
      <% if (products && products.length) { %>
        <% products.forEach(product => { %>
          <article class="product-card">
            <img src="<%= product.image %>" alt="<%= product.name %>" class="product-image" />
            <h3><%= product.name %></h3>
            <p><%= product.shortDescription || product.description %></p>
            <p><strong>$<%= Number(product.price || 0).toFixed(2) %></strong></p>
            <div class="wishlist-card-actions">
              <a href="/products/<%= product._id %>" class="btn-primary">Customize and Buy</a>
              <% if (currentUser) { %>
                <form method="POST" action="/wishlist/add/<%= product._id %>" class="inline-form wishlist-card-form" data-product-id="<%= product._id %>">
                  <button type="submit" class="wishlist-card-btn">Add to Wishlist</button>
                </form>
              <% } %>
            </div>
          </article>
        <% }) %>
      <% } else { %>
        <article class="builder-card">
          <h3>No pints found</h3>
          <p>Try another keyword or add products from admin dashboard.</p>
        </article>
      <% } %>
    </div>

    <div class="builder-grid top-gap">
      <article class="builder-card">
        <h2>How custom flavour picking works</h2>
        <p>Select a product, choose 3 or 4 scoop layers, then pick the exact flavours available for that pint.</p>
        <p>During checkout, choose one-time delivery or a weekly subscription and track your order from your account.</p>
      </article>
      <article class="builder-card">
        <h2>Your Wishlist</h2>
        <p>Save pints while browsing and review all saved items later from one dedicated page.</p>
        <% if (currentUser) { %>
          <a href="/wishlist" class="btn-outline">Go to My Wishlist</a>
        <% } else { %>
          <a href="/auth/signin" class="btn-outline">Sign In to Use Wishlist</a>
        <% } %>
      </article>
      <article class="builder-card">
        <h2>Need bulk orders?</h2>
        <p>Use our contact page for events, office gifting, and seasonal corporate pint drops.</p>
        <a href="/contact" class="btn-outline">Contact Team ScoopCraft</a>
      </article>
    </div>
  </div>
</section>

<%- include('partials/footer') %>