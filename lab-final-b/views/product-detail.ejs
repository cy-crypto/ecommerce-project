<%- include('partials/header') %>

<section class="product-detail">
  <div class="detail-grid container">
    <img src="<%= product.image %>" alt="<%= product.name %>" class="detail-image sc-animate" data-animate="fade-right" />
    <div class="product-detail-panel sc-animate" data-animate="fade-left">
      <h1 class="product-title"><%= product.name %></h1>

      <div class="product-meta-row">
        <div class="product-price-chip" aria-label="Product price">
          <span class="product-price-chip__label">Price</span>
          <strong>$<%= Number(product.price || 0).toFixed(2) %></strong>
        </div>
        <div class="product-stock-chip <%= Number(product.stock || 0) > 10 ? 'in-stock' : (Number(product.stock || 0) > 0 ? 'low-stock' : 'out-stock') %>" aria-label="Product stock status">
          <span class="product-stock-chip__label">Stock</span>
          <strong><%= Number(product.stock || 0) > 0 ? `${product.stock} available` : 'Out of stock' %></strong>
        </div>
      </div>

      <article class="product-description-card">
        <h3>About This Pint</h3>
        <p><%= product.description %></p>
      </article>

      <form id="customAddToCartForm" class="builder-card" data-product-id="<%= product._id %>" data-product-image="<%= product.image %>">
        <h3>Customize This Pint</h3>
        <label class="choice-row">
          <input type="radio" name="scoopCount" value="3" checked />
          <span>
            <strong>3-Flavour Classic</strong>
            <small>Pick exactly 3 flavours</small>
          </span>
        </label>
        <label class="choice-row">
          <input type="radio" name="scoopCount" value="4" />
          <span>
            <strong>4-Flavour Deluxe</strong>
            <small>Pick exactly 4 flavours</small>
          </span>
        </label>

        <% if (product.flavourOptions && product.flavourOptions.length) { %>
          <div class="product-selected-flavour-preview" data-flavour-preview aria-live="polite"></div>
          <div class="flavour-picker-grid top-gap">
            <% product.flavourOptions.forEach(flavour => { %>
              <label class="flavour-picker" style="--flavour-accent:<%= flavour.color || '#ffe5c2' %>">
                <input type="checkbox" name="selectedFlavours" value="<%= flavour.name %>" />
                <span class="flavour-badge"></span>
                <strong><%= flavour.name %></strong>
                <small><%= flavour.note || 'Signature layer' %></small>
              </label>
            <% }) %>
          </div>
          <p id="productSelectionHelp" class="selection-help">Pick exactly 3 flavours.</p>
          <p id="productSelectionStatus" class="selection-status">0 of 3 selected</p>
        <% } %>

        <div class="product-actions top-gap">
          <button id="addToCartBtn" type="submit" class="btn-primary btn-glow">Add To Cart</button>
        </div>
      </form>

      <div class="product-actions top-gap">
        <% if (currentUser) { %>
          <form method="POST" action="/wishlist/toggle/<%= product._id %>" class="inline-form wishlist-toggle-form" data-product-id="<%= product._id %>">
            <button
              id="addToWishlistBtn"
              type="submit"
              class="btn-wishlist <%= isWishlisted ? 'active' : '' %>"
              data-wishlisted="<%= isWishlisted ? 'true' : 'false' %>"
            >
              <%= isWishlisted ? 'Remove from Wishlist' : 'Add to Wishlist' %>
            </button>
          </form>
          <a href="/wishlist" class="btn-outline">View Wishlist</a>
        <% } else { %>
          <a href="/auth/signin" class="btn-outline">Sign in for wishlist</a>
        <% } %>
      </div>

      <div id="cartMessage" style="display:none;"></div>
      <div id="wishlistMessage" style="display:none;"></div>
    </div>
  </div>
</section>




<section class="builder-section">
  <div class="container">
    <h2 class="section-title sc-animate" data-animate="fade-up">You May Also Like</h2>
    <div class="products-grid">
      <% if (relatedProducts && relatedProducts.length) { %>
        <% relatedProducts.forEach((item, idx) => { %>
          <article class="product-card product-card-clickable sc-animate" data-animate="fade-up" data-delay="<%= idx * 80 %>" data-href="/products/<%= item._id %>" tabindex="0" role="link" aria-label="Open <%= item.name %>">
            <img src="<%= item.image %>" alt="<%= item.name %>" class="product-image" />
            <h3><%= item.name %></h3>
            <p>$<%= Number(item.price || 0).toFixed(2) %></p>
            <a href="/products/<%= item._id %>" class="btn-primary">View Details</a>
          </article>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
