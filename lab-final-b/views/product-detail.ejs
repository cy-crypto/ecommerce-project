<%- include('partials/header') %>

<section class="product-detail">
  <div class="detail-grid container">
    <img src="<%= product.image %>" alt="<%= product.name %>" class="detail-image" />
    <div>
      <h1><%= product.name %></h1>
      <p><strong>Price:</strong> $<%= product.price.toFixed(2) %></p>
      <p><strong>Stock:</strong> <%= product.stock %></p>
      <p><%= product.description %></p>

      <form id="customAddToCartForm" class="builder-card" data-product-id="<%= product._id %>">
        <h3>Customize This Pint</h3>
        <label class="choice-row">
          <input type="radio" name="scoopCount" value="3" checked />
          <span>
            <strong>3-Flavour Classic</strong>
            <small>Pick exactly 3 flavours</small>
          </span>
        </label>
        <label class="choice-row">
          <input type="radio" name="scoopCount" value="4" />
          <span>
            <strong>4-Flavour Deluxe</strong>
            <small>Pick exactly 4 flavours</small>
          </span>
        </label>

        <% if (product.flavourOptions && product.flavourOptions.length) { %>
          <div class="flavour-picker-grid top-gap">
            <% product.flavourOptions.forEach(flavour => { %>
              <label class="flavour-picker" style="--flavour-accent:<%= flavour.color || '#ffe5c2' %>">
                <input type="checkbox" name="selectedFlavours" value="<%= flavour.name %>" />
                <span class="flavour-badge"></span>
                <strong><%= flavour.name %></strong>
                <small><%= flavour.note || 'Signature layer' %></small>
              </label>
            <% }) %>
          </div>
          <p id="productSelectionHelp" class="selection-help">Pick exactly 3 flavours.</p>
          <p id="productSelectionStatus" class="selection-status">0 of 3 selected</p>
        <% } %>

        <div class="product-actions top-gap">
          <button id="addToCartBtn" type="submit" class="btn-primary">Add To Cart</button>
        </div>
      </form>

      <div class="product-actions top-gap">
        <% if (currentUser) { %>
          <form method="POST" action="/wishlist/toggle/<%= product._id %>" class="inline-form wishlist-toggle-form" data-product-id="<%= product._id %>">
            <button
              id="addToWishlistBtn"
              type="submit"
              class="btn-wishlist <%= isWishlisted ? 'active' : '' %>"
              data-wishlisted="<%= isWishlisted ? 'true' : 'false' %>"
            >
              <%= isWishlisted ? 'Remove from Wishlist' : 'Add to Wishlist' %>
            </button>
          </form>
          <a href="/wishlist" class="btn-outline">View Wishlist</a>
        <% } else { %>
          <a href="/auth/signin" class="btn-outline">Sign in for wishlist</a>
        <% } %>
      </div>

      <div id="cartMessage" style="display:none;"></div>
      <div id="wishlistMessage" style="display:none;"></div>

      <div class="builder-grid top-gap">
        <article class="builder-card">
          <h3>Product Highlights</h3>
          <p>Made in small batches with rich ingredients and flavor-balanced profiles.</p>
          <div class="flavour-chip-wrap">
            <span class="flavour-chip">Fresh Churned</span>
            <span class="flavour-chip">Cold Packed</span>
            <span class="flavour-chip">Flavor Layered</span>
          </div>
        </article>
        <article class="builder-card">
          <h3>Purchase Confidence</h3>
          <p>Transparent pricing, cart review, and checkout summaries help customers buy with confidence.</p>
          <a href="/checkout" class="btn-outline">Go to Checkout</a>
        </article>
      </div>
    </div>
  </div>
</section>

<section class="builder-section">
  <div class="container">
    <div class="builder-grid">
      <article class="builder-card">
        <h2>Ingredients and Sourcing</h2>
        <p>We focus on dependable sourcing and premium mix-ins for consistent quality in every pint shipped.</p>
      </article>
      <article class="builder-card">
        <h2>Shipping and Handling</h2>
        <p>Orders are insulated for cold-chain delivery to keep texture and flavor intact from kitchen to doorstep.</p>
      </article>
      <article class="builder-card">
        <h2>Admin-Driven Product Details</h2>
        <p>This product page is connected to admin-managed catalog and SEO settings, including metadata and canonical details.</p>
      </article>
      <article class="builder-card">
        <h2>Need Assistance?</h2>
        <p>Use the chat assistant for flavor recommendations, shipping questions, and order flow guidance.</p>
      </article>
    </div>
  </div>
</section>

<section class="builder-section">
  <div class="container">
    <h2 class="section-title">You May Also Like</h2>
    <div class="products-grid">
      <% if (relatedProducts && relatedProducts.length) { %>
        <% relatedProducts.forEach(item => { %>
          <article class="product-card">
            <img src="<%= item.image %>" alt="<%= item.name %>" class="product-image" />
            <h3><%= item.name %></h3>
            <p>$<%= Number(item.price || 0).toFixed(2) %></p>
            <a href="/products/<%= item._id %>" class="btn-primary">View Details</a>
          </article>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>


