    <footer class="main-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <h4>ScoopCraft Pints</h4>
            <p>Small-batch, custom ice cream pints made fresh every week.</p>
          </div>
          <div>
            <h4>Explore</h4>
            <p><a href="/">Home</a></p>
            <p><a href="/products">Build Your Pint</a></p>
          </div>
          <div>
            <h4>Support</h4>
            <p><a href="/about">About</a></p>
            <p><a href="/contact">Contact</a></p>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; <%= new Date().getFullYear() %> ScoopCraft Pints. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <button id="chatbotToggle" class="chatbot-toggle" type="button" aria-label="Open chat assistant">Chat</button>
    <section id="chatbotPanel" class="chatbot-panel" aria-label="ScoopCraft Assistant">
      <header class="chatbot-header">
        <div>
          <strong>ScoopCraft Assistant</strong>
          <p>Ask about wishlist, checkout, flavours, and orders.</p>
        </div>
        <button id="chatbotClose" type="button" class="chatbot-close" aria-label="Close chat">×</button>
      </header>
      <div id="chatbotBody" class="chatbot-body">
        <div class="chatbot-msg bot">
          <p>Hello! Need help with products, wishlist, cart, or checkout?</p>
        </div>
      </div>
      <div class="chatbot-prompts">
        <button type="button" class="chatbot-prompt" data-question="What flavours do you recommend?">Flavour Picks</button>
        <button type="button" class="chatbot-prompt" data-question="How does wishlist work?">Wishlist Help</button>
        <button type="button" class="chatbot-prompt" data-question="What are shipping and delivery options?">Shipping</button>
        <button type="button" class="chatbot-prompt" data-question="How do subscriptions work?">Subscriptions</button>
      </div>
      <form id="chatbotForm" class="chatbot-form">
        <input id="chatbotInput" type="text" placeholder="Type your question..." autocomplete="off" />
        <button type="submit">Send</button>
      </form>
    </section>

    <script src="/js/script.js"></script>
  </body>
</html>


