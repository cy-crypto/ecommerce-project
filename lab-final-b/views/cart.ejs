<%- include('partials/header') %>

<section class="cart-page">
  <div class="container">
    <h1 class="page-title sc-animate" data-animate="fade-up">🛒 Your Cart</h1>
    <p class="page-subtitle sc-animate" data-animate="fade-up">Review your custom pints, confirm quantities, and continue with secure checkout.</p>

    <% if (!cartItems || cartItems.length === 0) { %>
      <div class="cart-empty sc-animate" data-animate="zoom-in">
        <div class="cart-empty-icon">🧁</div>
        <h2>Your cart is empty</h2>
        <p>Start adding your favorite pints and custom flavour mixes.</p>
        <a href="/products" class="btn-primary btn-glow">Browse Products</a>
      </div>
    <% } else { %>
      <div class="cart-layout">
        <div class="cart-items-panel sc-animate" data-animate="fade-right">
          <table class="data-table cart-table">
            <thead>
              <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% cartItems.forEach(item => { %>
                <tr>
                  <td>
                    <strong><%= item.product.name %></strong>
                    <% if (item.selectedFlavours && item.selectedFlavours.length) { %>
                      <p class="cart-custom muted"><strong>Custom:</strong> <%= item.scoopCount %>-flavour mix - <%= item.selectedFlavours.join(', ') %></p>
                    <% } %>
                  </td>
                  <td>$<%= item.product.price.toFixed(2) %></td>
                  <td>
                    <form action="/cart/update" method="POST" class="inline-form cart-qty-form">
                      <input type="hidden" name="productId" value="<%= item.product._id %>" />
                      <input type="hidden" name="itemIndex" value="<%= item.itemIndex %>" />
                      <input type="number" name="quantity" min="1" value="<%= item.quantity %>" />
                      <button type="submit" class="btn-outline btn-sm">Update</button>
                    </form>
                  </td>
                  <td><strong>$<%= item.itemTotal.toFixed(2) %></strong></td>
                  <td>
                    <form action="/cart/remove" method="POST" class="inline-form">
                      <input type="hidden" name="productId" value="<%= item.product._id %>" />
                      <input type="hidden" name="itemIndex" value="<%= item.itemIndex %>" />
                      <button type="submit" class="btn-outline btn-remove">Remove</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <aside class="cart-summary-card-v2 sc-animate" data-animate="fade-left">
          <div class="cart-summary-header">
            <h2>💰 Order Total <button type="button" class="info-icon-btn info-trigger" data-info-title="Order Total" data-info-body="Order total includes subtotal, tax, and shipping based on your current cart contents.">i</button></h2>
          </div>
          <div class="cart-summary-rows">
            <p><span>Subtotal</span> <strong>$<%= subtotal.toFixed(2) %></strong></p>
            <p><span>Tax (8%)</span> <strong>$<%= tax.toFixed(2) %></strong></p>
            <p><span>Shipping</span> <strong>$<%= shipping.toFixed(2) %></strong></p>
          </div>
          <div class="cart-summary-divider"></div>
          <p class="cart-total-row"><span>Total</span> <strong class="cart-total-amount">$<%= total.toFixed(2) %></strong></p>
          <a href="/checkout" class="btn-primary btn-glow full-width cart-checkout-btn">🔒 Proceed to Checkout</a>
          <form action="/cart/clear" method="POST" class="inline-form full-width-form">
            <button type="submit" class="btn-outline full-width">Clear Cart</button>
          </form>
          <div class="cart-summary-note">
            <span>💡</span>
            <p class="muted">Signed-in users can track all placed orders from My Orders.</p>
          </div>
        </aside>
      </div>

      <div class="builder-grid top-gap">
        <article class="builder-card sc-animate" data-animate="fade-up">
          <h2>✅ Checkout Readiness</h2>
          <ul class="tick-list">
            <li>Verify quantity and customization choices</li>
            <li>Confirm shipping information in checkout</li>
            <li>Choose one-time or subscription plan</li>
            <li>Apply coupon code during checkout if available</li>
          </ul>
        </article>
        <article class="builder-card sc-animate" data-animate="fade-up" data-delay="100">
          <h2>🛍️ Need More Choices?</h2>
          <p>Continue shopping to add more flavor combinations before finalizing your order.</p>
          <a href="/products" class="btn-outline">Continue Shopping</a>
        </article>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>